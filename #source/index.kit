<!DOCTYPE html>
<html>

<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>Cozy House</title>
	<link rel="stylesheet" type="text/css" href="css/style.css">
</head>

<body> 

	<div class="wrapper">

		<!-- @import "header.html" -->

		<div class="content">

			<section class="hero">
				<div class="container">
					<div class="hero__row">
						<div class="hero__body">
							<h1 class="hero__title">Not only people need a house</h1>
							<div class="hero__text">
								<p>We offer to give a chance to a little and nice puppy with an extremely wide and open heart. He or she will love you more than anybody else in the world, you will see!</p>
							</div>
							<a href="" class="hero__link link">Make a friend</a>
						</div>
						<div class="hero__img">
							<img src="../img/hero-img.png" alt="puppy">
						</div>
					</div>
				</div>
			</section>

		</div>

		<!-- @import "footer.html" -->

	</div>

	<!-- Scripts -->
		<script src="js/main.js"></script>
</body>

</html>